  "version": "0.2.0",
  "configurations": [
    {
      "name": "PowerShell: 启动项目",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}\\start-project-safe.ps1",
      "cwd": "${workspaceFolder}",
      "args": []
    },
    {
      "name": "PowerShell: 强制重启并启动项目",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}\\start-project-safe.ps1",
      "cwd": "${workspaceFolder}",
      "args": [
        "-ForceRestart"
      ]
    },
    {
      "name": "PowerShell: Launch Current File",
      "type": "PowerShell",
      "request": "launch",
      "script": "${file}",
      "args": []
    }
  ]
}
